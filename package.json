{
  "name": "remove-release-asset",
  "version": "1.0.0",
  "private": true,
  "description": "Delete a release asset from an existing GitHub Release",
  "main": "lib/index.js",
  "scripts": {
    "bundle": "pnpm run format:write && pnpm run package",
    "build": "tsc",
    "format:write": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "pnpm exec eslint .",
    "package": "pnpm dlx rimraf ./dist && pnpm rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "pnpm run package -- --watch",
    "test": "jest",
    "all": "pnpm run build && pnpm run format:write && pnpm run lint && pnpm run test && pnpm run package"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flcdrg/remove-release-asset-action"
  },
  "keywords": [
    "actions",
    "node"
  ],
  "author": "flcdrg",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.0",
    "minimatch": "^10.2.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@octokit/types": "^16.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-circus": "^30.2.0",
    "js-yaml": "^4.1.1",
    "nerdbank-gitversioning": "^3.9.50",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "rollup-plugin-license": "^3.7.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
